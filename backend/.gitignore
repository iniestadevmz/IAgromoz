# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Caches
*.so
*.egg
*.egg-info/
dist/
build/

# Virtual environments
venv/
backend/venv/

# Django
*.log
local_settings.py
db.sqlite3
/media/

# Migrations — manter __init__.py, ignorar o resto
*/migrations/*.py
!*/migrations/__init__.py
**/migrations/*.pyc
**/migrations/__pycache__/

# PyCharm / VSCode / IDEs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# System files
.DS_Store
Thumbs.db

# Secrets
.env

# Testes e ferramentas de desenvolvimento
.pytest_cache/
.hypothesis/
htmlcov/
.coverage
coverage.xml
*.cover
pytest.ini
conftest.py

# Kiro (IDE local)
.kiro/

# Ficheiros gerados / irrelevantes para produção
freeze
=3.1
runtime.txt
